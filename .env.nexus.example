# ============================================================
# NEXUS AI DUAL-BRAIN SYSTEM - ENVIRONMENT CONFIGURATION
# ============================================================
# COPY file ini menjadi .env.nexus lalu isi dengan nilai asli.
# JANGAN PERNAH commit file .env.nexus ke repository!

# === API KEY GOOGLE GEMINI (ROUND-ROBIN) ===
GEMINI_KEY_01=YOUR_GEMINI_KEY_HERE
GEMINI_KEY_02=YOUR_GEMINI_KEY_HERE
GEMINI_KEY_03=YOUR_GEMINI_KEY_HERE
GEMINI_KEY_04=YOUR_GEMINI_KEY_HERE
GEMINI_KEY_05=YOUR_GEMINI_KEY_HERE
GEMINI_KEY_06=YOUR_GEMINI_KEY_HERE
GEMINI_KEY_07=YOUR_GEMINI_KEY_HERE
GEMINI_KEY_08=YOUR_GEMINI_KEY_HERE
GEMINI_KEY_09=YOUR_GEMINI_KEY_HERE
GEMINI_KEY_10=YOUR_GEMINI_KEY_HERE

# === ROBLOX OPEN CLOUD ===
ROBLOX_UNIVERSE_ID=YOUR_UNIVERSE_ID
ROBLOX_PLACE_ID=YOUR_PLACE_ID
ROBLOX_OPEN_CLOUD_API_KEY=YOUR_ROBLOX_API_KEY

# === TELEGRAM OBSERVABILITY ===
TELEGRAM_CHAT_ID=@your_channel_or_chatid
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN

# === GITHUB TOKEN (Opsional - untuk RAG search rate limit lebih tinggi) ===
GITHUB_TOKEN=YOUR_GITHUB_TOKEN

# === ROBLOX MCP URL (Opsional - untuk integrasi Roblox Studio) ===
ROBLOX_MCP_URL=

# === KONFIGURASI VPS ===
VPS_WEBHOOK_PORT=8080
